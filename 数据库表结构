-- ============================================================
-- 西南财经大学培养方案查询系统 - 数据库 Schema
-- 数据库: SQLite
-- ============================================================

-- 学院表
CREATE TABLE IF NOT EXISTS college (
    id          INTEGER PRIMARY KEY,
    name        TEXT NOT NULL UNIQUE,
    name_en     TEXT
);

-- 专业表
CREATE TABLE IF NOT EXISTS major (
    id              INTEGER PRIMARY KEY,
    name            TEXT NOT NULL,
    code            TEXT NOT NULL,           -- 专业代码, 如 080901
    college_id      INTEGER NOT NULL,
    total_credits   REAL NOT NULL,           -- 毕业最低学分要求
    degree          TEXT,                    -- 授予学位
    FOREIGN KEY (college_id) REFERENCES college(id),
    UNIQUE(name, code)
);

-- 课程表
CREATE TABLE IF NOT EXISTS course (
    code            TEXT PRIMARY KEY,        -- 课程代码, 如 CST205
    name            TEXT NOT NULL,           -- 课程名称
    name_en         TEXT,                    -- 英文名称
    credits         REAL NOT NULL,           -- 学分
    weekly_hours    INTEGER,                 -- 周学时
    total_hours     INTEGER,                 -- 总学时
    teaching_hours  INTEGER DEFAULT 0,       -- 课堂学时
    practice_hours  INTEGER DEFAULT 0,       -- 实践学时
    nature          TEXT NOT NULL,           -- 课程性质: 必修/选修/限选
    department      TEXT NOT NULL,           -- 开课学院
    semester        INTEGER,                 -- 开课学期
    CHECK (nature IN ('必修', '选修', '限选')),
    CHECK (credits > 0),
    CHECK (total_hours >= 0)
);

-- 专业-课程关联表 (多对多)
CREATE TABLE IF NOT EXISTS major_course (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    major_id        INTEGER NOT NULL,
    course_code     TEXT NOT NULL,
    FOREIGN KEY (major_id) REFERENCES major(id),
    FOREIGN KEY (course_code) REFERENCES course(code),
    UNIQUE(major_id, course_code)
);

-- 索引
CREATE INDEX IF NOT EXISTS idx_course_name ON course(name);
CREATE INDEX IF NOT EXISTS idx_course_nature ON course(nature);
CREATE INDEX IF NOT EXISTS idx_course_department ON course(department);
CREATE INDEX IF NOT EXISTS idx_major_college ON major(college_id);
CREATE INDEX IF NOT EXISTS idx_major_course_major ON major_course(major_id);
CREATE INDEX IF NOT EXISTS idx_major_course_course ON major_course(course_code);
