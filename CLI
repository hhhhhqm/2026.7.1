# CLI 界面
# ============================================================
def print_header(title):
    width = 60
    print()
    print("=" * width)
    print(f"  {title}")
    print("=" * width)


def print_table(headers, rows, col_widths=None):
    """简单的表格打印"""
    if not rows:
        print("  (无数据)")
        return

    if col_widths is None:
        col_widths = []
        for i, h in enumerate(headers):
            max_len = len(h)
            for r in rows:
                if i < len(r):
                    max_len = max(max_len, len(str(r[i])))
            col_widths.append(min(max_len + 2, 30))

    # 表头
    header_line = "".join(str(h).ljust(col_widths[i]) for i, h in enumerate(headers))
    print(f"  {header_line}")
    print(f"  {'-' * sum(col_widths)}")

    # 数据行
    for r in rows:
        line = "".join(str(r[i]).ljust(col_widths[i]) for i in range(len(headers)))
        print(f"  {line}")


