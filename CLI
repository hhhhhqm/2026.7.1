def handle_choice(choice):
    if choice == "1":
        do_compulsory_query()
    elif choice == "2":
        do_course_detail_query()
    elif choice == "3":
        do_major_credits_query()
    elif choice == "4":
        do_majors_by_course_query()
    elif choice == "5":
        do_college_overview_query()
    elif choice == "6":
        do_keyword_search()
    elif choice == "0":
        print("\n感谢使用，再见！")
        return False
    else:
        print("\n无效选项，请重新输入。")
    return True


def do_compulsory_query():
    print_header("查询某专业的必修课列表")
    majors = get_all_majors()
    print("  可选专业:")
    for i, m in enumerate(majors):
        print(f"    {i+1}. {m['name']} ({m['college']})")

    name = input("\n  请输入专业名称: ").strip()
    if not name:
        return

    rows = query_compulsory_courses(name)
    print_header(f"[{name}] 必修课列表 ({len(rows)}门)")
    print_table(
        ["课程代码", "课程名称", "学分", "总学时", "学期", "性质"],
        [[r["code"], r["name"], r["credits"], r["total_hours"],
          r["semester"], r["nature"]] for r in rows],
    )
    total = sum(r["credits"] for r in rows)
    print(f"\n  必修课总计: {len(rows)}门, {total}学分")


def do_course_detail_query():
    print_header("查询某门课程的学分、学时信息")
    name = input("  请输入课程名称(支持模糊匹配): ").strip()
    if not name:
        return

    rows = query_course_detail(name)
    print_header(f"搜索 '{name}' 的结果 ({len(rows)}条)")
    for r in rows:
        print(f"""
  课程代码:   {r['code']}
  课程名称:   {r['name']}
  英文名称:   {r['name_en']}
  学分:       {r['credits']}
  周学时:     {r['weekly_hours']}
  总学时:     {r['total_hours']} (课堂{r['teaching_hours']} + 实践{r['practice_hours']})
  课程性质:   {r['nature']}
  开课学院:   {r['department']}
  开课学期:   第{r['semester']}学期""")


def do_major_credits_query():
    print_header("查询某专业的总学分要求")
    majors = get_all_majors()
    print("  可选专业:")
    for i, m in enumerate(majors):
        print(f"    {i+1}. {m['name']} ({m['college']})")

    name = input("\n  请输入专业名称: ").strip()
    if not name:
        return

    total, detail = query_major_credits(name)
    if not total:
        print(f"  未找到专业: {name}")
        return

    print_header(f"[{name}] 学分要求")
    print(f"  专业名称:   {total['name']}")
    print(f"  专业代码:   {total['code']}")
    print(f"  所属学院:   {total['college_name']}")
    print(f"  授予学位:   {total['degree']}")
    print(f"  毕业最低:   {total['total_credits']} 学分")
    print()
    print("  学分分布:")
    for d in detail:
        print(f"    {d['nature']}: {d['course_count']}门, {d['credit_sum']}学分")


def do_majors_by_course_query():
    print_header("查询开设某门课程的所有专业")
    name = input("  请输入课程名称(支持模糊匹配): ").strip()
    if not name:
        return

    rows = query_majors_by_course(name)
    print_header(f"开设 '{name}' 相关课程的专业 ({len(rows)}条)")
    print_table(
        ["专业名称", "专业代码", "所属学院", "课程名称", "学分", "性质"],
        [[r["major_name"], r["major_code"], r["college_name"],
          r["course_name"], r["credits"], r["nature"]] for r in rows],
    )


def do_college_overview_query():
    print_header("查询某学院下所有专业的培养方案概览")
    colleges = get_all_colleges()
    print("  可选学院:")
    for i, c in enumerate(colleges):
        print(f"    {i+1}. {c['name']}")

    name = input("\n  请输入学院名称: ").strip()
    if not name:
        return

    rows = query_college_overview(name)
    print_header(f"[{name}] 专业培养方案概览 ({len(rows)}个专业)")
    print_table(
        ["专业名称", "专业代码", "总学分", "学位", "课程数", "必修学分", "选修学分"],
        [[r["major_name"], r["major_code"], r["total_credits"],
          r["degree"], r["course_count"],
          r["compulsory_credits"] or 0, r["elective_credits"] or 0]
         for r in rows],
    )


def do_keyword_search():
    print_header("关键词模糊搜索课程名称")
    keyword = input("  请输入搜索关键词: ").strip()
    if not keyword:
        return

    rows = search_courses(keyword)
    print_header(f"搜索 '{keyword}' 的结果 ({len(rows)}条)")
    print_table(
        ["课程代码", "课程名称", "学分", "总学时", "性质", "开课学院"],
        [[r["code"], r["name"], r["credits"], r["total_hours"],
          r["nature"], r["department"]] for r in rows],
    )


def main():
    if not os.path.exists(DB_PATH):
        print("数据库不存在，请先运行: python db/init_db.py")
        return

    running = True
    while running:
        show_menu()
        choice = input("  请选择操作 [0-6]: ").strip()
        try:
            running = handle_choice(choice)
        except Exception as e:
            print(f"\n  出错: {e}")

        if running:
            input("\n  按回车键继续...")


if __name__ == "__main__":
    main()
