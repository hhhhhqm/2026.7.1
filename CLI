"""
培养方案查询系统 - CLI 界面
西南财经大学 2024级人才培养方案
支持6项查询功能
"""

import os
import sqlite3
import textwrap

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH = os.path.join(BASE_DIR, "db", "curriculum.db")


def get_connection():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    return conn


# ============================================================
# 查询功能 1: 查询某专业的必修课列表
# ============================================================
def query_compulsory_courses(major_name):
    """查询指定专业的必修课列表"""
    sql = """
        SELECT c.code, c.name, c.credits, c.total_hours, c.semester, c.nature
        FROM course c
        JOIN major_course mc ON c.code = mc.course_code
        JOIN major m ON mc.major_id = m.id
        WHERE m.name = ? AND c.nature = '必修'
        ORDER BY c.semester, c.code
    """
    conn = get_connection()
    rows = conn.execute(sql, (major_name,)).fetchall()
    conn.close()
    return rows


# ============================================================
# 查询功能 2: 查询某门课程的学分、学时信息
# ============================================================
def query_course_detail(course_name):
    """查询课程详细信息"""
    sql = """
        SELECT code, name, name_en, credits, weekly_hours,
               total_hours, teaching_hours, practice_hours,
               nature, department, semester
        FROM course
        WHERE name LIKE ?
    """
    conn = get_connection()
    rows = conn.execute(sql, (f"%{course_name}%",)).fetchall()
    conn.close()
    return rows


# ============================================================
# 查询功能 3: 查询某专业的总学分要求
# ============================================================
def query_major_credits(major_name):
    """查询专业总学分要求及分项统计"""
    sql_total = """
        SELECT m.name, m.code, m.total_credits, m.degree,
               c.name as college_name
        FROM major m
        JOIN college c ON m.college_id = c.id
        WHERE m.name = ?
    """
    sql_detail = """
        SELECT c.nature,
               COUNT(*) as course_count,
               SUM(c.credits) as credit_sum
        FROM course c
        JOIN major_course mc ON c.code = mc.course_code
        JOIN major m ON mc.major_id = m.id
        WHERE m.name = ?
        GROUP BY c.nature
    """
    conn = get_connection()
    total = conn.execute(sql_total, (major_name,)).fetchone()
    detail = conn.execute(sql_detail, (major_name,)).fetchall()
    conn.close()
    return total, detail


# ============================================================
# 查询功能 4: 查询开设某门课程的所有专业
# ============================================================
def query_majors_by_course(course_name):
    """查询开设某门课程的所有专业"""
    sql = """
        SELECT m.name as major_name, m.code as major_code,
               c.name as college_name,
               co.name as course_name, co.code as course_code,
               co.credits, co.nature
        FROM major m
        JOIN major_course mc ON m.id = mc.major_id
        JOIN course co ON mc.course_code = co.code
        JOIN college c ON m.college_id = c.id
        WHERE co.name LIKE ?
        ORDER BY c.name, m.name
    """
    conn = get_connection()
    rows = conn.execute(sql, (f"%{course_name}%",)).fetchall()
    conn.close()
    return rows


# ============================================================
# 查询功能 5: 查询某学院下所有专业的培养方案概览
# ============================================================
def query_college_overview(college_name):
    """查询学院下所有专业的培养方案概览"""
    sql = """
        SELECT m.name as major_name, m.code as major_code,
               m.total_credits, m.degree,
               (SELECT COUNT(*) FROM major_course mc WHERE mc.major_id = m.id) as course_count,
               (SELECT SUM(c.credits) FROM course c
                JOIN major_course mc ON c.code = mc.course_code
                WHERE mc.major_id = m.id AND c.nature = '必修') as compulsory_credits,
               (SELECT SUM(c.credits) FROM course c
                JOIN major_course mc ON c.code = mc.course_code
                WHERE mc.major_id = m.id AND c.nature != '必修') as elective_credits
        FROM major m
        JOIN college c ON m.college_id = c.id
        WHERE c.name = ?
        ORDER BY m.name
    """
    conn = get_connection()
    rows = conn.execute(sql, (college_name,)).fetchall()
    conn.close()
    return rows


# ============================================================
# 查询功能 6: 关键词模糊搜索课程名称
# ============================================================
def search_courses(keyword):
    """模糊搜索课程"""
    sql = """
        SELECT DISTINCT code, name, name_en, credits,
               total_hours, nature, department
        FROM course
        WHERE name LIKE ? OR name_en LIKE ? OR code LIKE ?
        ORDER BY credits DESC, name
    """
    conn = get_connection()
    pattern = f"%{keyword}%"
    rows = conn.execute(sql, (pattern, pattern, pattern)).fetchall()
    conn.close()
    return rows


# ============================================================
# 辅助函数: 获取列表选项
# ============================================================
def get_all_majors():
    conn = get_connection()
    rows = conn.execute(
        "SELECT m.name, c.name as college FROM major m "
        "JOIN college c ON m.college_id = c.id ORDER BY c.name, m.name"
    ).fetchall()
    conn.close()
    return rows


def get_all_colleges():
    conn = get_connection()
    rows = conn.execute("SELECT name FROM college ORDER BY id").fetchall()
    conn.close()
    return rows


